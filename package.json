{
  "type": "module",
  "name": "urls.wtf",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "clean": "rm -rf .svelte-kit .vercel node_modules",
    "dev": "concurrently 'pnpm run dev:svelte' 'pnpm run db'",
    "dev:svelte": "vite dev",
    "build": "vite build",
    "build-prod": "svelte-kit sync && prisma generate && prisma db push && vite build",
    "preview": "vite preview",
    "ts-check": "svelte-kit sync && prisma generate && svelte-check --tsconfig ./tsconfig.json",
    "ts-check:watch": "svelte-kit sync && prisma generate && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "ci": "npm run lint && npm run ts-check && npm run build && npm run test",
    "db": "prisma dev > /dev/null 2>&1",
    "db:push": "concurrently --kill-others 'pnpm run db' 'sleep 1 && pnpm prisma db push --accept-data-loss'",
    "test": "sh -c 'pnpm run db & DBPID=$!; pnpm run test:e2e; CODE=$?; kill $DBPID 2>/dev/null; wait $DBPID 2>/dev/null; exit $CODE'",
    "test:ui": "sh -c 'pnpm run db & DBPID=$!; pnpm run test:e2e:ui; CODE=$?; kill $DBPID 2>/dev/null; wait $DBPID 2>/dev/null; exit $CODE'",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.4.2",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "prisma": "^7.7.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.6",
    "svelte-preprocess": "^6.0.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.9"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "7.7.0",
    "@prisma/extension-accelerate": "^3.0.1",
    "@tailwindcss/postcss": "^4.2.4",
    "concurrently": "^9.2.1"
  },
  "packageManager": "pnpm@10.33.0"
}
